{
  "$schema": "https://ai-manager.app/schemas/config-registry.schema.json",
  "version": 1,
  "app": {
    "showTrayTitle": true,
    "showTraySessions": true,
    "systemNotificationsEnabled": false,
    "collapseSidebarByDefault": false,
    "thirdPartyProviderPricingEnabled": true,
    "uiLanguage": "zh",
    "defaultTerminalApp": "terminal",
    "defaultEditorApp": "cursor",
    "trayTitleMaxChars": null,
    "sessionTrayCountStyle": "superscriptCompact",
    "trayPulseWaiting": true,
    "focusSessionShortcut": "Command+Control+J",
    "ledControl": {
      "enabled": false,
      "waitingMode": 5,
      "runningMode": 1,
      "idleMode": 2
    }
  },
  "customProviders": [
    {
      "id": "custom:team-plan",
      "name": "Team Plan",
      "localizedName": {
        "zh": "团队计划",
        "en": "Team Plan"
      },
      "description": "团队 OpenRouter 供应商",
      "docUrl": "https://example.com/provider-docs",
      "modelSuggestions": [
        "claude-sonnet-4-6"
      ],
      "env": {
        "ANTHROPIC_BASE_URL": "https://openrouter.ai/api",
        "ANTHROPIC_MODEL": "claude-sonnet-4-6"
      },
      "source": "custom"
    }
  ],
  "profiles": [
    {
      "id": "user-openrouter",
      "name": "OpenRouter User",
      "description": "全局开发默认配置",
      "providerId": "custom:team-plan",
      "settings": {
        "env": {
          "ANTHROPIC_AUTH_TOKEN": "token"
        },
        "model": "claude-sonnet-4-6"
      },
      "createdAt": "2026-04-18T12:00:00+08:00",
      "updatedAt": "2026-04-18T12:00:00+08:00"
    }
  ],
  "bindings": {
    "userProfileId": "user-openrouter",
    "userLastAppliedAt": "2026-04-18T12:00:00+08:00"
  }
}
