{
  "name": "ai-manager",
  "private": true,
  "version": "0.19.0",
  "description": "AI Manager - Claude Code 桌面配置管理应用",
  "author": "maguowei",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/maguowei/ai-manager.git"
  },
  "homepage": "https://github.com/maguowei/ai-manager",
  "bugs": {
    "url": "https://github.com/maguowei/ai-manager/issues"
  },
  "packageManager": "pnpm@11.2.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "preview": "vite preview",
    "tauri": "tauri",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "fmt-check": "make fmt-check",
    "fmt-rust-check": "make fmt-rust-check",
    "check": "biome check --write .",
    "biome:ci": "biome ci .",
    "commitlint": "commitlint",
    "prepare": "node -e \"const { spawnSync } = require('node:child_process'); const git = spawnSync('git', ['rev-parse', '--git-dir'], { stdio: 'ignore' }); if (git.status === 0) { const hook = spawnSync('lefthook', ['install', '--reset-hooks-path'], { stdio: 'inherit' }); process.exit(hook.status ?? 1); }\""
  },
  "dependencies": {
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.2",
    "@codemirror/view": "^6.43.0",
    "@hookform/resolvers": "^5.4.0",
    "@lezer/highlight": "^1.2.3",
    "@pierre/diffs": "1.2.2",
    "@pierre/trees": "1.0.0-beta.4",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-virtual": "^3.13.24",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-dialog": "2.7.1",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@uiw/codemirror-theme-xcode": "^4.25.10",
    "@uiw/react-codemirror": "^4.25.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.3.0",
    "github-markdown-css": "^5.9.0",
    "lucide-react": "^1.16.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.76.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "recharts": "3.8.1",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@tauri-apps/cli": "^2.11.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.1.7",
    "jsdom": "^29.1.1",
    "lefthook": "^2.1.8",
    "typescript": "~5.8.3",
    "vite": "^7.3.3",
    "vitest": "^4.1.7"
  }
}
