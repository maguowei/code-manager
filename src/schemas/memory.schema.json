{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "memory",
  "title": "Memory Form Data",
  "type": "object",
  "required": ["name", "content", "targetType"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "readOnly": true },
    "name": { "type": "string", "minLength": 1 },
    "content": { "type": "string", "default": "" },
    "targetType": {
      "type": "string",
      "enum": ["claude", "rule"],
      "default": "claude"
    },
    "rulePath": {
      "type": "string",
      "default": "",
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*(?:^|/)\\.(?:/|$)).+\\.md$"
    },
    "pathPatterns": {
      "type": "array",
      "default": [],
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
